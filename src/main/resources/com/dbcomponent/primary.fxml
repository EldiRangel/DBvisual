<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dbcomponent.PrimaryController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label text="Componente DB Desacoplado">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <VBox alignment="CENTER" spacing="5.0">
         <children>
            <Label text="Seleccione el Motor de Base de Datos:" />
            <ComboBox fx:id="adapterCombo" prefWidth="200.0" />
         </children>
      </VBox>
      
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleQuery" text="Probar Query" />
            <Button mnemonicParsing="false" onAction="#handleTransaction" text="Probar Transacción" />
         </children>
      </HBox>
      
      <VBox spacing="5.0" VBox.vgrow="ALWAYS">
         <children>
            <Label text="Consola de Resultados:" />
            <TextArea fx:id="logArea" editable="false" prefHeight="150.0" prefWidth="460.0" promptText="Esperando ejecución..." wrapText="true" />
         </children>
      </VBox>
   </children>
</VBox>